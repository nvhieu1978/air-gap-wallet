# Network Configuration
# For Mainnet, uncomment the following two lines and comment out the Preprod lines:
# NETWORK_PARAM="--mainnet"
# BLOCKFROST_URL="https://cardano-mainnet.blockfrost.io/api/v0"

# For Preprod (Default)
NETWORK_PARAM="--testnet-magic 2"
BLOCKFROST_URL="https://cardano-preprod.blockfrost.io/api/v0"

# Blockfrost API Key (Project ID)
# Get your API key from https://blockfrost.io
BLOCKFROST_API_KEY="YOUR_BLOCKFROST_PROJECT_ID_HERE"
